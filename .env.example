# 이 파일을 복사해서 ".env" 파일을 만들고, 아래에 클로드 API 열쇠를 채워 넣으세요.
#   cp .env.example .env
# 열쇠는 https://console.anthropic.com 에서 발급합니다.
# .env 파일은 .gitignore에 등록되어 있어 깃에 올라가지 않습니다 (안전).

ANTHROPIC_API_KEY=

# 영구 저장(Supabase). 채우면 이야기가 저장되고, 비우면 저장 없이 동작.
# Supabase 프로젝트 → Project Settings → API 에서 확인합니다.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# 경량 처리(Gemini Flash) — 줄거리 요약·연대 문헌·인물 분석 보고서에 사용.
# 비우면 그 기능들이 폴백(요약 없이 동작 / 보고서 발급 불가)으로 돕니다.
# 열쇠는 https://aistudio.google.com/apikey 에서 무료로 발급합니다.
GEMINI_API_KEY=

# (선택) 서버 포트. 비워두면 8787 사용.
PORT=8787
